# Variáveis SERVER-ONLY (nunca usar prefixo VITE_ — o Vite expõe VITE_* no bundle do navegador).
# Para dev local com `vercel dev`, copie para `.env.local`. Na Vercel, configure em
# Settings → Environment Variables.

# Chave da API do Gemini (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modelo de visão a usar (gemini-2.5-flash é estável; gemini-3.5-flash é mais novo)
GEMINI_MODEL=gemini-2.5-flash

# Senha de acesso ao app
APP_PASSWORD=

# Segredo para assinar o token de sessão (use uma string longa e aleatória)
AUTH_SECRET=
